// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`




  generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String
  phone           String           @unique
  role            UserRole         @default(CLIENT)
  createdAt       DateTime         @default(now())
  providerProfile ProviderProfile?
}

model ProviderProfile {
  id                    String             @id @default(cuid())
  userId                String             @unique
  county                String
  serviceCategory       String
  policeClearanceNumber String?
  idNumber              String?
  certificationNumber   String?
  verificationStatus    VerificationStatus @default(PENDING)
  adminNotes            String?
  createdAt             DateTime           @default(now())
  bookings              Booking[]
  ratings               Rating[]
  user                  User               @relation(fields: [userId], references: [id])

  // Rating aggregation fields
  averageRating         Float?             @default(0)
  totalRatings          Int                @default(0)
  totalFiveStar         Int                @default(0)
  totalFourStar         Int                @default(0)
  totalThreeStar        Int                @default(0)
  totalTwoStar          Int                @default(0)
  totalOneStar          Int                @default(0)
  rankingTier           RankingTier        @default(NEW)
}

model Booking {
  id                 String          @id @default(cuid())
  providerProfileId  String
  clientName         String
  clientPhone        String
  county             String
  scheduledDate      DateTime
  notes              String?
  status             BookingStatus   @default(REQUESTED)
  createdAt          DateTime        @default(now())
  amount             Float?
  paymentStatus      PaymentStatus   @default(PENDING)
  mpesaPhoneNumber   String?
  mpesaTransactionId String?
  mpesaReceiptNumber String?
  paymentMethod      String?         @default("MPESA")
  paymentCreatedAt   DateTime?
  developerFee       Float?          @default(0)
  providerAmount     Float?          @default(0)
  commissionRate     Float?          @default(0.12)
  serviceConfirmed   Boolean         @default(false)
  serviceConfirmedAt DateTime?
  clientConfirmed   Boolean         @default(false)
  clientConfirmedAt DateTime?
  suspiciousActivity Boolean         @default(false)
  securityFlag       String?
  escrowReleased     Boolean         @default(false)
  ratingEligibleAt   DateTime?
  providerProfile    ProviderProfile @relation(fields: [providerProfileId], references: [id])
  rating             Rating?
}

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Rating {
  id                  String       @id @default(cuid())
  bookingId           String       @unique
  providerProfileId   String
  clientPhone         String
  rating              Int          // 1-5 stars
  comment             String?
  ratingLegitimacyScore Float       @default(0) // 0-1 score for legitimacy
  automatedFlags      String[]     @default([]) // Flags for suspicious patterns
  createdAt           DateTime     @default(now())
  ratingEligibleAt    DateTime     // When rating became eligible (after dual confirmation)
  ratedAt             DateTime     @default(now())
  booking             Booking      @relation(fields: [bookingId], references: [id])
  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id])
  
  @@index([providerProfileId])
  @@index([bookingId])
}

enum RankingTier {
  NEW            // 0-5 ratings
  EMERGING       // 6-20 ratings
  ESTABLISHED    // 21-50 ratings
  TOP_RATED      // 51-100 ratings
  ELITE          // 100+ ratings
}

